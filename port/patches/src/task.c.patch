-void SetWordTaskArg(u8 taskId, u8 dataElem, u32 value)
+// Host: callers stash 64-bit pointers here that the two s16 slots would truncate.
+// Keep the full value in a side table, still mirror the low 32 bits into the
+// slots, and on read prefer the side table only when its low 32 bits still match
+// the slots — so code that pokes the slots directly (32-bit value users) wins.
+static uintptr_t sWordArgs[NUM_TASKS][NUM_TASK_DATA];
+
+void SetWordTaskArg(u8 taskId, u8 dataElem, uintptr_t value)
 {
     if (dataElem < NUM_TASK_DATA - 1)
     {
         gTasks[taskId].data[dataElem] = value;
         gTasks[taskId].data[dataElem + 1] = value >> 16;
+        sWordArgs[taskId][dataElem] = value;
     }
