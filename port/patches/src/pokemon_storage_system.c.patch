 {
-    sStorage->movingMonSprite->oam.priority = priority;
+    // Host: called for the buttons/party cursor areas even with no mon grabbed,
+    // where movingMonSprite is NULL. A NULL sprite write is a harmless no-op on
+    // the GBA (no MMU) but faults on the host, so guard it.
+    if (sStorage->movingMonSprite != NULL)
+        sStorage->movingMonSprite->oam.priority = priority;
 }
 
