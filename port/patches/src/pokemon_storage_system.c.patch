         {
-            if (GetBoxMonDataAt(boxId, boxPosition, MON_DATA_HELD_ITEM) == ITEM_NONE)
+            // Host: empty slots have a NULL icon sprite; the GBA-benign NULL write
+            // faults here, so only touch slots that actually have an icon.
+            if (sStorage->boxMonsSprites[boxPosition] != NULL
+             && GetBoxMonDataAt(boxId, boxPosition, MON_DATA_HELD_ITEM) == ITEM_NONE)
                 sStorage->boxMonsSprites[boxPosition]->oam.objMode = ST_OAM_OBJ_BLEND;
         }
     }
@@ -5078,7 +5088,11 @@
 
